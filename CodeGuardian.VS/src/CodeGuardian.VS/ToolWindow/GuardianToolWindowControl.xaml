<UserControl x:Class="CodeGuardian.VS.ToolWindow.GuardianToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CodeGuardian.VS.ToolWindow"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="350"
             Background="#FF1E1E1E">

    <UserControl.Resources>
        <Style x:Key="EstiloRotuloSecao" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FFAAAAAA" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>

        <Style x:Key="EstiloContador" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EstiloRotuloContador" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FFCCCCCC" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>

        <Style x:Key="EstiloMetricaRotulo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#FFBBBBBB" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EstiloMetricaValor" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="EstiloNomeArquivo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <!-- Logo Code Guardian -->
            <Border Background="#FF2D2D2D" CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
                <Image Source="pack://application:,,,/CodeGuardian.VS;component/Resources/logo-codeguardian.png"
                       Height="48"
                       HorizontalAlignment="Left"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <!-- Cabecalho: Risk Score -->
            <TextBlock Style="{StaticResource EstiloRotuloSecao}"
                       Text="RISCO" />

            <Border Background="#FF2D2D2D" CornerRadius="4" Padding="12,10">
                <StackPanel>

                    <!-- Barra de progresso colorida -->
                    <Grid Margin="0,0,0,8">
                        <ProgressBar Height="8"
                                     Value="{Binding RiskProgress, Mode=OneWay}"
                                     Maximum="100"
                                     Background="#FF3D3D3D"
                                     BorderThickness="0"
                                     VerticalAlignment="Center">
                            <ProgressBar.Foreground>
                                <SolidColorBrush Color="{Binding RiskColor.Color, Mode=OneWay}" />
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </Grid>

                    <!-- Score e label -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{Binding RiskColor, Mode=OneWay}"
                                   Text="{Binding RiskScore, Mode=OneWay}" />
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{Binding RiskColor, Mode=OneWay}"
                                       Text="{Binding RiskLabel, Mode=OneWay}" />
                            <TextBlock FontSize="11"
                                       Foreground="#FF888888"
                                       Text="score de 0 a 100" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Indicador de analise em andamento -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,6,0,0"
                        Visibility="{Binding IsAnalyzing, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             HorizontalAlignment="Stretch"
                             Background="Transparent"
                             Foreground="#FF4FC3F7"
                             Width="200" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="10"
                           Foreground="#FF4FC3F7"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="10"
                       Foreground="#FF888888"
                       Margin="0,4,0,0"
                       Visibility="{Binding IsAnalyzing, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}" />

            <!-- Resumo de Issues por Severidade -->
            <TextBlock Style="{StaticResource EstiloRotuloSecao}"
                       Text="ISSUES" />

            <Border Background="#FF2D2D2D" CornerRadius="4" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Critical -->
                    <StackPanel Grid.Row="0" Grid.Column="0"
                                Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse Width="10" Height="10"
                                 Fill="#FFE74C3C"
                                 VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource EstiloContador}"
                                   Text="{Binding CountCritical}"
                                   Margin="6,0,0,0" />
                        <TextBlock Style="{StaticResource EstiloRotuloContador}"
                                   Text="Critical" />
                    </StackPanel>

                    <!-- Error -->
                    <StackPanel Grid.Row="0" Grid.Column="1"
                                Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse Width="10" Height="10"
                                 Fill="#FFE67E22"
                                 VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource EstiloContador}"
                                   Text="{Binding CountError}"
                                   Margin="6,0,0,0" />
                        <TextBlock Style="{StaticResource EstiloRotuloContador}"
                                   Text="Error" />
                    </StackPanel>

                    <!-- Warning -->
                    <StackPanel Grid.Row="1" Grid.Column="0"
                                Orientation="Horizontal">
                        <Ellipse Width="10" Height="10"
                                 Fill="#FFF1C40F"
                                 VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource EstiloContador}"
                                   Text="{Binding CountWarning}"
                                   Margin="6,0,0,0" />
                        <TextBlock Style="{StaticResource EstiloRotuloContador}"
                                   Text="Warning" />
                    </StackPanel>

                    <!-- Info -->
                    <StackPanel Grid.Row="1" Grid.Column="1"
                                Orientation="Horizontal">
                        <Ellipse Width="10" Height="10"
                                 Fill="#FF3498DB"
                                 VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource EstiloContador}"
                                   Text="{Binding CountInfo}"
                                   Margin="6,0,0,0" />
                        <TextBlock Style="{StaticResource EstiloRotuloContador}"
                                   Text="Info" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lista de Issues individuais -->
            <ItemsControl ItemsSource="{Binding Issues}" Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF2D2D2D" CornerRadius="3" Margin="0,2,0,0" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Barra de severidade -->
                                <Rectangle Grid.Column="0" Fill="{Binding SeverityColor}" RadiusX="2" RadiusY="2" Margin="0,0,6,0" />
                                <!-- RuleId -->
                                <TextBlock Grid.Column="1" Text="{Binding RuleId, Mode=OneWay}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{Binding SeverityColor, Mode=OneWay}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <!-- Mensagem e nome do arquivo -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Message, Mode=OneWay}"
                                               FontSize="11" Foreground="White"
                                               TextWrapping="Wrap" />
                                    <TextBlock FontSize="10" Foreground="#FF888888" Margin="0,2,0,0"
                                               ToolTip="{Binding CaminhoCompleto, Mode=OneWay}">
                                        <Run Text="{Binding NomeArquivo, Mode=OneWay}" />
                                        <Run Text=" :" />
                                        <Run Text="{Binding Line, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <!-- Categoria -->
                                <TextBlock Grid.Column="3" Text="{Binding Category, Mode=OneWay}"
                                           FontSize="9" Foreground="#FF666666"
                                           VerticalAlignment="Top" Margin="6,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Metricas por Arquivo -->
            <TextBlock Style="{StaticResource EstiloRotuloSecao}"
                       Text="METRICAS POR ARQUIVO" />

            <ItemsControl ItemsSource="{Binding FileMetrics}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="True" Margin="0,0,0,4">
                            <Expander.Header>
                                <TextBlock Style="{StaticResource EstiloNomeArquivo}"
                                           Text="{Binding NomeArquivo}"
                                           ToolTip="{Binding CaminhoCompleto}" />
                            </Expander.Header>
                            <Border Background="#FF2D2D2D"
                                    CornerRadius="0,0,4,4"
                                    Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="22" />
                                        <RowDefinition Height="22" />
                                        <RowDefinition Height="22" />
                                        <RowDefinition Height="22" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Style="{StaticResource EstiloMetricaRotulo}"
                                               Text="Total de linhas" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Style="{StaticResource EstiloMetricaValor}"
                                               Foreground="{Binding CorTotalLinhas}"
                                               Text="{Binding TotalLinhas}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Style="{StaticResource EstiloMetricaRotulo}"
                                               Text="Maior metodo (linhas)" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Style="{StaticResource EstiloMetricaValor}"
                                               Foreground="{Binding CorMaxMethod}"
                                               Text="{Binding MaxMethodLines}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Style="{StaticResource EstiloMetricaRotulo}"
                                               Text="Nesting maximo" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Style="{StaticResource EstiloMetricaValor}"
                                               Foreground="{Binding CorMaxNesting}"
                                               Text="{Binding MaxNesting}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Style="{StaticResource EstiloMetricaRotulo}"
                                               Text="Dependencias (ctor)" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Style="{StaticResource EstiloMetricaValor}"
                                               Foreground="{Binding CorDependencias}"
                                               Text="{Binding ConstructorDeps}" />
                                </Grid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Botão para abrir o relatório HTML completo -->
            <Button x:Name="BtnAbrirRelatorio" Content="Abrir Relatório HTML"
                    Margin="0,12,0,0" Padding="12,6"
                    Background="#FF0E639C" Foreground="White" BorderThickness="0"
                    FontSize="12" HorizontalAlignment="Left"
                    Click="BtnAbrirRelatorio_Click" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
